APP_NAME="PANSIN ACCESS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://pansin.bankbjb.co.id
APP_TIMEZONE=Asia/Jakarta

# Database
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=pansin_access
DB_USERNAME=pansin_user
DB_PASSWORD=

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=predis

# Cache
CACHE_DRIVER=redis
CACHE_PREFIX=pansin_

# Queue
QUEUE_CONNECTION=redis

# Session
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

# Broadcasting (Laravel Reverb)
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=pansin-access
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=https

# MQTT (EMQX)
MQTT_HOST=emqx
MQTT_PORT=1883
MQTT_CLIENT_ID=pansin-backend
MQTT_USERNAME=pansin_mqtt
MQTT_PASSWORD=
MQTT_KEEPALIVE=60
MQTT_CLEAN_SESSION=true
MQTT_USE_TLS=false
MQTT_TLS_PORT=8883

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@bankbjb.co.id"
MAIL_FROM_NAME="PANSIN ACCESS"

# WhatsApp Gateway
WHATSAPP_GATEWAY_URL=
WHATSAPP_GATEWAY_TOKEN=
WHATSAPP_GATEWAY_SENDER=

# MediaMTX (Livestream)
MEDIAMTX_API_URL=http://mediamtx:9997
MEDIAMTX_RTSP_URL=rtsp://mediamtx:8554
MEDIAMTX_WEBRTC_URL=http://mediamtx:8889

# Sanctum
SANCTUM_STATEFUL_DOMAINS=pansin.bankbjb.co.id

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=info
LOG_STACK=daily,stderr

# Filesystem
FILESYSTEM_DISK=local
SNAPSHOT_DISK=snapshots

# Rate Limiting
API_RATE_LIMIT=60
LOGIN_RATE_LIMIT=5
OTP_RATE_LIMIT=3

# Vault Settings
VAULT_SESSION_TIMEOUT_MINUTES=10
VAULT_ALARM_THRESHOLD_SECONDS=600

# Device Heartbeat
DEVICE_HEARTBEAT_INTERVAL=30
DEVICE_OFFLINE_THRESHOLD=90

# Security
CORS_ALLOWED_ORIGINS=https://pansin.bankbjb.co.id
IP_WHITELIST_ENABLED=false
IP_WHITELIST=

# Horizon
HORIZON_PREFIX=pansin_horizon:

# Prometheus Metrics
METRICS_ENABLED=true
METRICS_ROUTE_PREFIX=metrics
